# Auf dem DigitalOcean-Server als .env.local oder Export vor „npm run build“ + „npm run start“

NODE_ENV=production

# Next spricht ComfyUI nur intern an (Comfy lauscht 127.0.0.1 — siehe install-comfyui-do.sh)
COMFY_URL=http://127.0.0.1:8188

# WebSocket: automatisch wss://comfy.nemesis-video-ai.ch wenn die App unter nemesis-video-ai.ch läuft.
# Nur setzen, wenn du einen anderen WS-Host brauchst:
# NEXT_PUBLIC_COMFY_WS_URL=wss://comfy.nemesis-video-ai.ch

# Optional Cloud-Hybrid
# CLOUD_GEN_ENDPOINT=
# CLOUD_GEN_TOKEN=
